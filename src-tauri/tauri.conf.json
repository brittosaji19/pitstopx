{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PitStopX",
  "version": "1.0.0",
  "identifier": "dev.britto.pitstopx",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popover",
        "title": "PitStopX",
        "url": "index.html",
        "width": 372,
        "height": 600,
        "minWidth": 372,
        "minHeight": 120,
        "maxWidth": 372,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "center": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Claude Code usage limits + account switching in the tray.",
    "longDescription": "PitStopX surfaces your Claude Code 5-hour and weekly usage limits in the system tray and lets you switch between saved Claude accounts with one click when a limit is reached.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "signingIdentity": null,
      "exceptionDomain": ""
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"],
        "files": {
          "/usr/share/applications/dev.britto.pitstopx.desktop": "pkg/dev.britto.pitstopx.desktop"
        }
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "libayatana-appindicator-gtk3"],
        "files": {
          "/usr/share/applications/dev.britto.pitstopx.desktop": "pkg/dev.britto.pitstopx.desktop"
        }
      }
    }
  }
}
